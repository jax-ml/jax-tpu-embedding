# Library.
absl-py
flax >= 0.10.3
numpy
# Pre-release of JAX required for SparseCore TPUs.
jax[tpu] >= 0.10.0 --pre
portpicker

# Build utilities.
auditwheel
build
packaging
setuptools
wheel

# Testing.
chex
clu
einops
google-benchmark
optax
orbax
protobuf

